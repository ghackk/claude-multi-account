# Maintainer: Gyanesh Kumar <ghackk@users.noreply.github.com>
pkgname=multi-claude
pkgver=1.0.0
pkgrel=1
pkgdesc="Run multiple Claude CLI accounts with shared settings and plugins"
arch=('any')
url="https://github.com/ghackk/claude-multi-account"
license=('MIT')
depends=('bash' 'jq')
source=("$pkgname-$pkgver.tar.gz::https://github.com/ghackk/claude-multi-account/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

package() {
    cd "claude-multi-account-${pkgver}"
    install -Dm755 unix/claude-menu.sh "$pkgdir/usr/bin/multi-claude"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
